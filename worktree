#!/usr/bin/env sh
#
# bin/worktree — manage git worktrees with isolated dev services.
#
# Each worktree gets a unique "slot" N (primary checkout is slot 0) that
# drives a non-colliding port set, so worktrees run their own Postgres +
# Redis + Rails server at once: PORT = BASE + N * PORT_STRIDE. The slot is
# the single source of truth, persisted as WORKTREE_SLOT in the worktree's
# gitignored .env, which mise loads first so it overrides the defaults.
#
# Usage:
#   bin/worktree add <slug> [<type>] [--no-start] [--prefix <ns>]
#       type defaults to "feat"; branch namespace <ns> defaults to empty
#       (no namespace). Set it via --prefix or $WORKTREE_BRANCH_PREFIX.
#   bin/worktree adopt [<path>] [--start]           # adopt an existing worktree
#   bin/worktree list
#   bin/worktree rm <slug|name|path|slot> [--delete-branch] [--force]
#   bin/worktree reprovision [<target>]         # rewrite a worktree's .env to the current contract
#   bin/worktree services <start|stop|status>   # shared dev daemons (one set per machine)
#
set -eu

# Slot-0 base ports. Override per-repo via env (e.g. an app's mise.toml
# [env]) so an app that must coexist with another on the same machine can
# shift its whole port range; slot N is still BASE + N * PORT_STRIDE.
DB_PORT_BASE="${DB_PORT_BASE:-5431}"
REDIS_PORT_BASE="${REDIS_PORT_BASE:-6379}"
WEB_PORT_BASE="${WEB_PORT_BASE:-3000}"
MAIL_SMTP_PORT_BASE="${MAIL_SMTP_PORT_BASE:-1025}"
MAIL_UI_PORT_BASE="${MAIL_UI_PORT_BASE:-8025}"
# Stride is wide enough that no slot lands on a well-known port (e.g. a
# system Postgres on 5432): slot 1 -> +10, slot 2 -> +20, ...
PORT_STRIDE=10

# Echo a slot's five service ports, space-separated, in the fixed order
# db redis web mail_smtp mail_ui. Single source for the slot->port math.
ports_for_slot() {
  slot=$1
  printf '%s %s %s %s %s' \
    "$((DB_PORT_BASE + slot * PORT_STRIDE))" \
    "$((REDIS_PORT_BASE + slot * PORT_STRIDE))" \
    "$((WEB_PORT_BASE + slot * PORT_STRIDE))" \
    "$((MAIL_SMTP_PORT_BASE + slot * PORT_STRIDE))" \
    "$((MAIL_UI_PORT_BASE + slot * PORT_STRIDE))"
}

# --- repo topology -----------------------------------------------------------
# Primary working tree (holds the real .git dir) is the first `git worktree
# list` entry; its basename is the repo name, its parent holds siblings.
main_worktree() {
  git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

# Registered worktree paths, one per line.
worktree_paths() {
  git worktree list --porcelain | awk '/^worktree /{print $2}'
}

# The token `rm` accepts for a worktree: the add-slug (dir basename minus the
# "<repo>-" prefix) or, for other worktrees (e.g. Claude isolation ones), the
# bare dir basename. Empty for the primary checkout.
slug_of_path() {
  base=$(basename "$1")
  [ "$1" = "$(main_worktree)" ] && return 0
  repo=$(basename "$(main_worktree)")
  case "$base" in
    "$repo"-*) printf '%s' "${base#"$repo"-}" ;;
    *) printf '%s' "$base" ;;
  esac
}

# Echo the WORKTREE_SLOT recorded in a worktree's .env, or empty.
slot_of_env() {
  env_file="$1/.env"
  [ -f "$env_file" ] || return 0
  grep -E '^[[:space:]]*WORKTREE_SLOT[[:space:]]*=' "$env_file" 2>/dev/null \
    | tail -n1 | cut -d= -f2 | sed "s/[[:space:]\"']//g"
}

# Slots currently in use across all worktrees. Primary == 0.
used_slots() {
  echo 0
  worktree_paths | while read -r wt; do
    s=$(slot_of_env "$wt")
    [ -n "$s" ] && echo "$s"
  done || true
}

next_free_slot() {
  used=$(used_slots)
  n=1
  while echo "$used" | grep -qx "$n"; do
    n=$((n + 1))
  done
  echo "$n"
}

# Resolve a slug | worktree dir name | path | slot number to a single
# registered worktree path on stdout. Errors (with candidates) on miss or
# ambiguity. This is what lets `rm` reach Claude isolation worktrees under
# .claude/worktrees/<name>, which don't follow the $repo-$slug naming.
resolve_worktree() {
  arg=$1
  rw_main=$(main_worktree)
  rw_repo=$(basename "$rw_main")
  rw_parent=$(dirname "$rw_main")
  paths=$(worktree_paths)

  # 1. A path (absolute or relative) that is itself a registered worktree.
  if [ -d "$arg" ]; then
    abs=$(cd "$arg" 2>/dev/null && pwd)
    if [ -n "$abs" ] && echo "$paths" | grep -qx "$abs"; then
      echo "$abs"; return 0
    fi
  fi

  # 2. Legacy slug -> $repo-$slug sibling.
  if echo "$paths" | grep -qx "$rw_parent/$rw_repo-$arg"; then
    echo "$rw_parent/$rw_repo-$arg"; return 0
  fi

  # 3. Slot number -> the worktree whose .env records it (0 == primary).
  if echo "$arg" | grep -qE '^[0-9]+$'; then
    [ "$arg" = "0" ] && { echo "$rw_main"; return 0; }
    oldifs=$IFS; IFS='
'
    for wt in $paths; do
      [ "$(slot_of_env "$wt")" = "$arg" ] && { IFS=$oldifs; echo "$wt"; return 0; }
    done
    IFS=$oldifs
  fi

  # 4. Worktree directory basename (e.g. a Claude worktree's name).
  matches=""
  oldifs=$IFS; IFS='
'
  for wt in $paths; do
    [ "$(basename "$wt")" = "$arg" ] && matches="$matches$wt
"
  done
  IFS=$oldifs
  count=$(printf '%s' "$matches" | grep -c .)
  if [ "$count" -eq 1 ]; then
    printf '%s' "$matches" | sed '/^$/d'; return 0
  elif [ "$count" -gt 1 ]; then
    echo "worktree rm: '$arg' matches multiple worktrees:" >&2
    printf '%s' "$matches" | sed 's/^/  /' >&2
    return 1
  fi

  echo "worktree rm: no worktree matches '$arg'. Known worktrees:" >&2
  echo "$paths" | sed 's/^/  /' >&2
  return 1
}

# --- slot-allocation lock ----------------------------------------------------
# next_free_slot reads slots, but a slot only becomes "used" once provision()
# writes its .env — that gap lets two concurrent add/adopt calls claim the same
# N. Serialize alloc->provision with a lock in the shared git common dir, so
# every worktree of this repo contends on one file.
slot_lock_path() {
  common=$(git rev-parse --git-common-dir 2>/dev/null) || common=".git"
  case "$common" in /*) ;; *) common="$(pwd)/$common" ;; esac
  printf '%s/worktree-slot.lock' "$common"
}

SLOT_LOCK_HELD=""
SLOT_LOCK_DIR=""
slot_lock_release() {
  if [ -n "$SLOT_LOCK_HELD" ]; then
    exec 9>&- 2>/dev/null || true
    SLOT_LOCK_HELD=""
  fi
  if [ -n "$SLOT_LOCK_DIR" ]; then
    rmdir "$SLOT_LOCK_DIR" 2>/dev/null || true
    SLOT_LOCK_DIR=""
  fi
}
trap 'slot_lock_release; svc_lock_release' EXIT

slot_lock_acquire() {
  lock="$(slot_lock_path)"
  if command -v flock >/dev/null 2>&1; then
    exec 9>"$lock"
    flock 9
    SLOT_LOCK_HELD=1
  else
    # flock is Linux-only; mkdir is the portable atomic fallback — the create
    # succeeds for exactly one racer.
    lockdir="$lock.d"
    tries=0
    while ! mkdir "$lockdir" 2>/dev/null; do
      tries=$((tries + 1))
      if [ "$tries" -ge 150 ]; then
        echo "worktree: timed out waiting for slot lock ($lockdir)" >&2
        exit 1
      fi
      sleep 0.2
    done
    SLOT_LOCK_DIR="$lockdir"
  fi
}

# --- subcommands -------------------------------------------------------------
cmd_add() {
  slug=""
  type="feat"
  start=1
  # prefix defaults to empty (no namespace); the caller — typically an AI
  # agent — sets it via --prefix or $WORKTREE_BRANCH_PREFIX. prefix_from_cli
  # lets an explicit --prefix override the env var.
  prefix=""
  prefix_from_cli=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-start) start=0 ;;
      --prefix=*) prefix=${1#--prefix=}; prefix_from_cli=1 ;;
      --prefix)
        shift
        [ $# -gt 0 ] || { echo "worktree add: --prefix needs a value" >&2; exit 2; }
        prefix=$1; prefix_from_cli=1
        ;;
      --*) echo "worktree add: unknown flag $1" >&2; exit 2 ;;
      *)
        if [ -z "$slug" ]; then slug="$1"
        else type="$1"
        fi
        ;;
    esac
    shift
  done
  [ -n "$slug" ] || { echo "usage: bin/worktree add <slug> [<type>] [--no-start] [--prefix <ns>]" >&2; exit 2; }
  case "$slug" in */*) echo "worktree add: slug must not contain '/'" >&2; exit 2 ;; esac

  # Branch namespace prefix. --prefix wins; else $WORKTREE_BRANCH_PREFIX; else
  # empty. Empty means no namespace segment: branch is just "<type>/<slug>".
  [ "$prefix_from_cli" -eq 1 ] || prefix=${WORKTREE_BRANCH_PREFIX-}
  # Trim leading/trailing slashes so "ai/" never yields "ai//feat".
  prefix=$(printf '%s' "$prefix" | sed 's#^/*##; s#/*$##')

  main=$(main_worktree)
  repo=$(basename "$main")
  parent=$(dirname "$main")
  dest="$parent/$repo-$slug"
  if [ -n "$prefix" ]; then
    branch="$prefix/$type/$slug"
  else
    branch="$type/$slug"
  fi

  [ -e "$dest" ] && { echo "worktree add: $dest already exists" >&2; exit 1; }

  slot_lock_acquire
  slot=$(next_free_slot)
  read -r _ _ web_port _ _ <<EOF
$(ports_for_slot "$slot")
EOF

  echo "==> Creating worktree '$slug' (slot $slot)"
  echo "    path:   $dest"
  echo "    branch: $branch"

  git worktree add "$dest" -b "$branch"
  provision "$dest" "$slot"
  ensure_primary_shared
  slot_lock_release

  if [ "$start" -eq 1 ]; then
    echo "==> Booting services (mise run start)"
    (cd "$dest" && mise run start)
  else
    echo "==> Skipped boot (--no-start). Start later with: cd $dest && mise run start"
  fi

  echo "==> Done. Web server: http://localhost:$web_port"
}

# Write the per-worktree .env, copy the gitignored secrets a checkout doesn't
# carry, and trust the configs. Shared by add/adopt/reprovision.
#
# The .env contract is capability-gated (plan 0001 D6): an app opts in by
# setting WORKTREE_SERVICES=shared in its mise [env]. Gated apps get the
# namespace contract (shared daemons; database-suffix + Redis-index isolation);
# every other app gets today's slot-offset ports, byte-identical to before — so
# this code reaching unmigrated apps via `version = latest` changes nothing.
provision() {
  dest="$1"
  slot="$2"

  # Trust the worktree's mise config up front: reading WORKTREE_SERVICES/APP from
  # its [env] goes through `mise x`, which hard-errors on an untrusted config
  # non-interactively — so without this the capability probe would silently fail
  # and every fresh worktree fall back to the legacy contract.
  mise trust "$dest/mise.toml" >/dev/null 2>&1 || true
  [ -f "$dest/mise.local.toml" ] && mise trust "$dest/mise.local.toml" >/dev/null 2>&1 || true

  if [ "$(svc_app_env "$dest" WORKTREE_SERVICES)" = "shared" ]; then
    provision_shared "$dest" "$slot"
  else
    provision_legacy "$dest" "$slot"
  fi

  provision_copy_secrets "$dest"
}

# Legacy contract: slot-offset ports in .env (pre-shared-services behaviour).
provision_legacy() {
  dest="$1"
  slot="$2"
  read -r db_port redis_port web_port mail_smtp_port mail_ui_port <<EOF
$(ports_for_slot "$slot")
EOF

  echo "==> Writing $dest/.env (slot $slot: db=$db_port redis=$redis_port web=$web_port mail=$mail_smtp_port/$mail_ui_port)"
  cat > "$dest/.env" <<EOF
# Generated by bin/worktree — isolated dev services for this worktree.
# Slot $slot drives the ports; the slot's .env overrides any inherited
# parent mise config (a deeper config wins), so this works for nested worktrees.
WORKTREE_SLOT=$slot
DB_PORT=$db_port
REDIS_PORT=$redis_port
PORT=$web_port
MAIL_SMTP_PORT=$mail_smtp_port
MAIL_UI_PORT=$mail_ui_port
EOF
}

# Shared contract (plan 0001 D3/D5): one daemon set per machine; this worktree
# isolates via a per-app+slot database suffix and a registry-allocated Redis DB
# index. Only the web PORT stays slot-derived; DB/Mailpit ports come from the
# machine-global services config. The primary checkout (slot 0) is provisioned
# too — a committed mise default cannot encode the machine-local app_base, so
# without a slot-0 .env two apps' primaries would both land on Redis DB 0.
provision_shared() {
  dest="$1"
  slot="$2"

  app=$(svc_app_env "$dest" WORKTREE_APP)
  if [ -z "$app" ]; then
    echo "worktree: $dest sets WORKTREE_SERVICES=shared but WORKTREE_APP is empty." >&2
    echo "  WORKTREE_APP must name the app explicitly (SOCK_PREFIX is not the app name)." >&2
    echo "  Refusing to provision — database names would be underivable." >&2
    exit 1
  fi

  svc_ensure_registry
  svc_load_config
  base=$(svc_app_base "$app")
  redis_db=$((base + slot))
  if [ "$slot" = "0" ]; then suffix=""; else suffix="_s$slot"; fi
  web_port=$((WEB_PORT_BASE + slot * PORT_STRIDE))

  echo "==> Writing $dest/.env (shared: app=$app slot=$slot suffix='${suffix}' redis_db=$redis_db web=$web_port)"
  cat > "$dest/.env" <<EOF
# Generated by bin/worktree — shared dev services (plan 0001).
# Isolation is by namespace, not port: a per-app+slot database suffix and a
# Redis DB index. The Postgres/Redis/Mailpit daemons are shared per machine —
# manage them with: worktree services start
WORKTREE_SLOT=$slot
WORKTREE_APP=$app
WORKTREE_SERVICES=shared
WORKTREE_DB_SUFFIX=$suffix
PORT=$web_port
DB_HOST=localhost
DB_PORT=$PG_PORT
REDIS_DB=$redis_db
REDIS_URL=redis://localhost:$REDIS_PORT/$redis_db
MAIL_SMTP_PORT=$MAIL_SMTP_PORT
MAIL_UI_PORT=$MAIL_UI_PORT
EOF

  provision_dev_role
}

# Parity with the old postgres:setup task: ensure the developer's convenience
# database exists on the shared cluster so a bare `psql` works (initdb already
# made $USER a superuser). Best-effort — skipped, not fatal, when the shared
# Postgres is not up yet; app databases are still created by bin/setup /
# rails db:prepare as before.
provision_dev_role() {
  if ! svc_run pg_isready -h "$SVC_RUNTIME_DIR" -p "$PG_PORT" -q 2>/dev/null; then
    echo "    (shared Postgres down — skipping convenience db; run 'worktree services start')"
    return 0
  fi
  user=${USER:-$(id -un)}
  if [ "$(svc_run psql -h "$SVC_RUNTIME_DIR" -p "$PG_PORT" -d postgres -tAc "SELECT 1 FROM pg_database WHERE datname='$user'" 2>/dev/null)" != "1" ]; then
    svc_run createdb -h "$SVC_RUNTIME_DIR" -p "$PG_PORT" "$user" >/dev/null 2>&1 \
      && echo "    Created convenience database '$user'" || true
  fi
}

# Copy the gitignored artifacts a fresh checkout lacks and trust the configs.
# Shared by both contracts.
provision_copy_secrets() {
  dest="$1"
  main=$(main_worktree)

  # master.key is gitignored, so a checkout does not materialise it.
  if [ -f "$main/config/master.key" ] && [ ! -f "$dest/config/master.key" ]; then
    cp "$main/config/master.key" "$dest/config/master.key"
    echo "==> Copied config/master.key"
  fi

  # Procfile.dev is gitignored; without it `bin/dev start` aborts. Carry the
  # primary's copy, falling back to the tracked .example.
  if [ ! -f "$dest/Procfile.dev" ]; then
    if [ -f "$main/Procfile.dev" ]; then
      cp "$main/Procfile.dev" "$dest/Procfile.dev"
      echo "==> Copied Procfile.dev"
    elif [ -f "$dest/Procfile.dev.example" ]; then
      cp "$dest/Procfile.dev.example" "$dest/Procfile.dev"
      echo "==> Created Procfile.dev from Procfile.dev.example"
    fi
  fi

  # mise.local.toml is the gitignored per-machine override. Carry it over but
  # strip the port/slot/namespace keys — they live in .env, and a copied value
  # would outrank .env (mise.local.toml > _.file) and collide with the primary.
  if [ -f "$main/mise.local.toml" ] && [ "$dest" != "$main" ]; then
    grep -vE '^[[:space:]]*(PORT|DB_HOST|DB_PORT|REDIS_PORT|REDIS_DB|REDIS_URL|MAIL_SMTP_PORT|MAIL_UI_PORT|WORKTREE_SLOT|WORKTREE_APP|WORKTREE_SERVICES|WORKTREE_DB_SUFFIX)[[:space:]]*=' \
      "$main/mise.local.toml" > "$dest/mise.local.toml"
    echo "==> Copied mise.local.toml (port/slot/namespace keys stripped)"
  fi

  mise trust "$dest/mise.toml" >/dev/null 2>&1 || true
  [ -f "$dest/mise.local.toml" ] && mise trust "$dest/mise.local.toml" >/dev/null 2>&1 || true

  # rtk trusts .rtk/filters.toml relative to CWD, so trust it inside the
  # worktree or rtk prompts on first use there.
  if [ -f "$dest/.rtk/filters.toml" ] && command -v rtk >/dev/null 2>&1; then
    (cd "$dest" && rtk trust >/dev/null 2>&1) || true
    echo "==> Trusted rtk filters"
  fi
}

# Ensure the primary checkout (slot 0) carries a provisioned .env when the
# PRIMARY's own checkout is on shared services. Keyed on the primary's own mise
# [env], not the triggering worktree's: during the in-flight window where a
# feature branch has migrated but the main branch has not, the primary stays
# untouched (no spurious .env). Idempotent; a no-op once the primary already
# holds the shared contract.
ensure_primary_shared() {
  main=$(main_worktree)
  [ "$(svc_app_env "$main" WORKTREE_SERVICES)" = "shared" ] || return 0
  if [ -f "$main/.env" ] && grep -qE '^[[:space:]]*WORKTREE_SERVICES[[:space:]]*=[[:space:]]*shared([[:space:]]|$)' "$main/.env"; then
    return 0
  fi
  echo "==> Provisioning primary checkout (slot 0) for shared services"
  provision "$main" 0
}

# Bring an existing worktree (e.g. a Claude isolation worktree under
# .claude/worktrees/) into the scheme: allocate a slot and provision it.
cmd_adopt() {
  start=0
  target=""
  for arg in "$@"; do
    case "$arg" in
      --start) start=1 ;;
      --*) echo "worktree adopt: unknown flag $arg" >&2; exit 2 ;;
      *) target="$arg" ;;
    esac
  done
  [ -n "$target" ] || target="$(pwd)"
  [ -d "$target" ] || { echo "worktree adopt: $target not found" >&2; exit 1; }
  target=$(cd "$target" && pwd)

  if ! worktree_paths | grep -qx "$target"; then
    echo "worktree adopt: $target is not a git worktree" >&2
    exit 1
  fi
  main=$(main_worktree)
  [ "$target" = "$main" ] && { echo "worktree adopt: refusing to adopt the primary checkout" >&2; exit 1; }

  slot_lock_acquire
  existing=$(slot_of_env "$target")
  [ -n "$existing" ] && { echo "worktree adopt: already managed (slot $existing)" >&2; exit 1; }

  slot=$(next_free_slot)
  echo "==> Adopting $target (slot $slot)"
  provision "$target" "$slot"
  ensure_primary_shared
  slot_lock_release

  if [ "$start" -eq 1 ]; then
    echo "==> Booting services (mise run start)"
    (cd "$target" && mise run start)
  else
    echo "==> Adopted. Start with: cd $target && mise run start"
  fi
}

ROW_FMT='%-4s  %-22s  %-5s  %-5s  %-5s  %-4s  %s\n'

cmd_list() {
  main=$(main_worktree)
  runtime="${XDG_RUNTIME_DIR:-/tmp}"
  # SOCK_PREFIX (mise.toml [env]) namespaces the socket dir; read it via mise
  # so this script stays app-agnostic. Single quotes are intentional — the
  # expansion must happen in the inner mise shell, not here.
  # shellcheck disable=SC2016
  sock_prefix=$( (cd "$main" && mise x -- sh -c 'printf %s "${SOCK_PREFIX}"') 2>/dev/null )
  [ -n "$sock_prefix" ] || sock_prefix=pm
  # shellcheck disable=SC2059  # ROW_FMT is a fixed format constant, not input
  printf "$ROW_FMT" SLOT SLUG DB RED WEB PG PATH
  worktree_paths | while read -r wt; do
    slug=$(slug_of_path "$wt"); [ -n "$slug" ] || slug="-"
    slot=$(slot_of_env "$wt")
    if [ -z "$slot" ]; then
      # Primary has no .env but uses mise's slot-0 defaults; any other
      # slot-less worktree (e.g. an unadopted Claude one) has no ports.
      if [ "$wt" = "$main" ]; then
        slot=0
      else
        # shellcheck disable=SC2059
        printf "$ROW_FMT" "-" "$slug" "-" "-" "-" "-" "$wt"
        continue
      fi
    fi
    read -r db_port redis_port web_port _ _ <<EOF
$(ports_for_slot "$slot")
EOF
    # Probe this slot's OWN Postgres via its unix socket, not localhost TCP:
    # under WSL2 localhost is shared across distros, so a TCP probe can report
    # an unrelated process as "up". The socket dir is filesystem-local.
    if pg_isready -h "$runtime/$sock_prefix-$slot" -p "$db_port" -q 2>/dev/null; then
      pg=up
    else
      pg=down
    fi
    # shellcheck disable=SC2059
    printf "$ROW_FMT" "$slot" "$slug" "$db_port" "$redis_port" "$web_port" "$pg" "$wt"
  done || true
}

cmd_rm() {
  target_arg=""
  delete_branch=0
  force=0
  for arg in "$@"; do
    case "$arg" in
      --delete-branch) delete_branch=1 ;;
      --force) force=1 ;;
      --*) echo "worktree rm: unknown flag $arg" >&2; exit 2 ;;
      *) target_arg="$arg" ;;
    esac
  done
  [ -n "$target_arg" ] || { echo "usage: bin/worktree rm <slug|name|path|slot> [--delete-branch] [--force]" >&2; exit 2; }

  main=$(main_worktree)
  dest=$(resolve_worktree "$target_arg") || exit 1
  [ "$dest" = "$main" ] && { echo "worktree rm: refusing to remove the primary checkout" >&2; exit 1; }

  branch=$(git -C "$dest" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

  echo "==> Stopping services in $dest"
  (cd "$dest" && mise run stop) || true

  # Drop the gitignored artifacts provision() planted; otherwise every adopted
  # worktree (Claude ones included) would carry untracked files and force a
  # --force removal. Real uncommitted work still blocks removal without --force.
  for f in .env mise.local.toml config/master.key Procfile.dev; do
    rm -f "$dest/$f"
  done

  echo "==> Removing worktree $dest"
  if [ "$force" -eq 1 ]; then
    git worktree remove --force "$dest"
  else
    git worktree remove "$dest"
  fi

  # "HEAD" means the worktree was detached — no branch to report.
  if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
    :
  elif [ "$delete_branch" -eq 1 ]; then
    echo "==> Deleting branch $branch"
    git branch -D "$branch"
  else
    echo "    Branch '$branch' kept. Delete with: git branch -D $branch"
  fi
}

# SessionStart-hook entry point. When a shell opens inside a Claude Code
# isolation worktree (.claude/worktrees/<name>), adopt it into a slot so its
# dev services don't collide with the primary checkout. Adopt-only: services
# stay DOWN. A silent no-op everywhere else, and on every run after the first.
# Wire it as `command: bin/worktree autoadopt` in .claude/settings.json.
#
# There is deliberately no auto-remove counterpart: tearing a worktree down on
# session end would risk unfinished/uncommitted work. Remove explicitly with
# `bin/worktree rm <name>` (accepts the worktree dir name, path, or slot).
cmd_autoadopt() {
  case "$PWD" in
    */.claude/worktrees/*) ;;
    *) exit 0 ;;
  esac
  command -v git >/dev/null 2>&1 || exit 0
  if [ -f .env ] && grep -qE '^[[:space:]]*WORKTREE_SLOT[[:space:]]*=' .env; then
    exit 0
  fi
  # adopt guards against the primary checkout / an already-managed worktree;
  # never let a failure abort the session.
  cmd_adopt . || true
}

# --- shared dev services (plan 0001 D1/D4) -----------------------------------
# One Postgres + one Redis + one Mailpit per machine, shared by every worktree
# of every app. Isolation moves to namespaces (db name / redis index) set per
# worktree by provision(); this section owns only the daemons themselves.
#
# ~/.config is the single XDG base stable across login / IDE / hook / cron
# shells, so it anchors the config, registry, lock and pinned-version mise.toml.
# The volatile data/runtime roots (XDG_STATE_HOME / XDG_RUNTIME_DIR are NOT
# stable across WSL2 shells) are resolved once and recorded in the registry, so
# two shells with different XDG env can never initdb two rival "shared"
# clusters.

svc_config_dir() {
  printf '%s/propitech-dev' "${XDG_CONFIG_HOME:-$HOME/.config}"
}

# Machine-global lock around start/stop and every registry write — the
# repo-scoped slot lock cannot serialize two different apps. flock when
# available, mkdir otherwise (same fallback shape as the slot lock, fd 8 vs 9).
SVC_LOCK_HELD=""
SVC_LOCK_DIR=""
svc_lock_release() {
  if [ -n "$SVC_LOCK_HELD" ]; then
    exec 8>&- 2>/dev/null || true
    SVC_LOCK_HELD=""
  fi
  if [ -n "$SVC_LOCK_DIR" ]; then
    rmdir "$SVC_LOCK_DIR" 2>/dev/null || true
    SVC_LOCK_DIR=""
  fi
}

svc_lock_acquire() {
  cfg="$(svc_config_dir)"
  mkdir -p "$cfg"
  lock="$cfg/lock"
  if command -v flock >/dev/null 2>&1; then
    exec 8>"$lock"
    flock 8
    SVC_LOCK_HELD=1
  else
    lockdir="$lock.d"
    tries=0
    while ! mkdir "$lockdir" 2>/dev/null; do
      tries=$((tries + 1))
      if [ "$tries" -ge 150 ]; then
        echo "worktree services: timed out waiting for lock ($lockdir)" >&2
        exit 1
      fi
      sleep 0.2
    done
    SVC_LOCK_DIR="$lockdir"
  fi
}

# Registry: a flat KEY=value file read/written with grep (no eval of file
# contents). Holds the resolved data/runtime roots; PRO-121 adds per-app bases.
svc_registry_get() {
  reg="$(svc_config_dir)/registry"
  [ -f "$reg" ] || return 0
  grep -E "^$1=" "$reg" 2>/dev/null | tail -n1 | cut -d= -f2-
}

svc_registry_set() {
  cfg="$(svc_config_dir)"
  reg="$cfg/registry"
  mkdir -p "$cfg"
  tmp="$reg.tmp.$$"
  if [ -f "$reg" ]; then
    grep -vE "^$1=" "$reg" > "$tmp" 2>/dev/null || : > "$tmp"
  else
    : > "$tmp"
  fi
  printf '%s=%s\n' "$1" "$2" >> "$tmp"
  mv "$tmp" "$reg"
}

# Resolve the data + runtime roots ONCE, recording them; later runs read them
# back so the cluster location is stable regardless of the calling shell's XDG.
# Sets SVC_DATA_DIR / SVC_RUNTIME_DIR.
svc_ensure_registry() {
  SVC_DATA_DIR=$(svc_registry_get SVC_DATA_DIR)
  SVC_RUNTIME_DIR=$(svc_registry_get SVC_RUNTIME_DIR)
  if [ -z "$SVC_DATA_DIR" ]; then
    SVC_DATA_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/propitech-dev"
    svc_registry_set SVC_DATA_DIR "$SVC_DATA_DIR"
  fi
  if [ -z "$SVC_RUNTIME_DIR" ]; then
    SVC_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/propitech-dev"
    svc_registry_set SVC_RUNTIME_DIR "$SVC_RUNTIME_DIR"
  fi
}

# Read one variable from an app's resolved mise [env] in <dir>. Empty if unset
# or if mise is unavailable. The inner script is double-quoted only to inject
# the var NAME; the value expands in the mise shell, not here.
svc_app_env() {
  dir="$1"
  var="$2"
  command -v mise >/dev/null 2>&1 || return 0
  (cd "$dir" 2>/dev/null && mise x -- sh -c "printf '%s' \"\${$var:-}\"") 2>/dev/null
}

# Per-app Redis base (stride 16), allocated once in the machine registry under
# the global lock, then stable. REDIS_DB = app_base + slot, so each app owns a
# contiguous 16-slot band; the shared Redis runs with `databases 1024` (64 apps).
svc_app_base() {
  app="$1"
  key="APP_BASE_$app"
  svc_lock_acquire
  base=$(svc_registry_get "$key")
  if [ -z "$base" ]; then
    reg="$(svc_config_dir)/registry"
    n=0
    [ -f "$reg" ] && n=$(grep -cE '^APP_BASE_' "$reg" 2>/dev/null | tr -d ' ')
    base=$((n * 16))
    svc_registry_set "$key" "$base"
  fi
  svc_lock_release
  printf '%s' "$base"
}

# Machine-global ports config, written with defaults on first run then
# user-editable — the one place to dodge a squatted well-known port (e.g. a
# Docker Redis already holding 6379). Sets PG_PORT / REDIS_PORT / MAIL_*_PORT.
svc_load_config() {
  PG_PORT=5431
  REDIS_PORT=6379
  MAIL_SMTP_PORT=1025
  MAIL_UI_PORT=8025
  conf="$(svc_config_dir)/config"
  if [ -f "$conf" ]; then
    # shellcheck disable=SC1090
    . "$conf"
  fi
}

svc_write_defaults() {
  cfg="$(svc_config_dir)"
  conf="$cfg/config"
  if [ ! -f "$conf" ]; then
    cat > "$conf" <<'EOF'
# propitech-dev shared services — machine-global ports.
# Edit to dodge a squatted well-known port; applies to every app on this machine.
PG_PORT=5431
REDIS_PORT=6379
MAIL_SMTP_PORT=1025
MAIL_UI_PORT=8025
EOF
  fi
  # Pinned daemon versions: mise loads this when we invoke daemons via
  # `mise -C <cfg> x --`, so the shared services run one canonical version set
  # whatever any app pins. Written once, then editable.
  mt="$cfg/mise.toml"
  if [ ! -f "$mt" ]; then
    cat > "$mt" <<'EOF'
# propitech-dev shared services — pinned daemon versions.
# One canonical set for every app's shared Postgres/Redis/Mailpit. Edit to bump.
[tools]
postgres = "16"
redis = "7.4"
mailpit = "latest"
EOF
  fi
}

# Run a daemon/client through the pinned-version config with the app's mise
# [env] scrubbed: the manager runs under the app's `mise exec`, so without this
# the app's DB_PORT / SOCK_DIR / PG_DATA_DIR / REDIS_PORT… would leak into the
# shared daemons and point them at the wrong place.
#
# 8>&- 9>&- close the lock fds before exec so a long-lived daemon started while
# the lock is held (Postgres, Redis) does NOT inherit and pin it — otherwise the
# daemon keeps fd 8 open after start exits and the machine-global flock never
# releases, deadlocking the next start. Harmless for the short-lived probes.
svc_run() {
  env -u DB_PORT -u DB_HOST -u DB_USER -u DB_PASS -u DB_NAME \
      -u REDIS_PORT -u REDIS_URL -u REDIS_DB \
      -u PORT -u MAIL_SMTP_PORT -u MAIL_UI_PORT \
      -u PG_DATA_DIR -u SOCK_DIR -u SOCK_PREFIX -u WORKTREE_SLOT \
      -u WORKTREE_DB_SUFFIX -u WORKTREE_APP -u WORKTREE_SERVICES \
      mise -C "$(svc_config_dir)" x -- "$@" 8>&- 9>&-
}

# Retry a verification predicate briefly — daemons fork before they bind.
svc_retry() {
  i=0
  while [ "$i" -lt 30 ]; do
    "$1" && return 0
    i=$((i + 1))
    sleep 0.1
  done
  return 1
}

# Process name for a pid, portably: /proc on Linux (WSL2), ps elsewhere (macOS).
svc_proc_comm() {
  if [ -r "/proc/$1/comm" ]; then
    cat "/proc/$1/comm" 2>/dev/null
  else
    ps -p "$1" -o comm= 2>/dev/null
  fi
}

svc_log_dir()      { printf '%s/logs' "$SVC_DATA_DIR"; }
svc_pg_data()      { printf '%s/postgres' "$SVC_DATA_DIR"; }
svc_redis_sock()   { printf '%s/redis.sock' "$SVC_RUNTIME_DIR"; }
svc_redis_pid()    { printf '%s/redis.pid' "$SVC_RUNTIME_DIR"; }
svc_mailpit_pid()  { printf '%s/mailpit.pid' "$SVC_RUNTIME_DIR"; }
svc_mailpit_db()   { printf '%s/mailpit.db' "$SVC_DATA_DIR"; }

# --- per-service start / verify ----------------------------------------------
# Postgres listens on both the unix socket (probes — WSL2 shares localhost, so a
# TCP probe can report an unrelated process as "up") and TCP 127.0.0.1 (apps
# connect via DB_HOST/DB_PORT).
svc_start_postgres() {
  pgdata="$(svc_pg_data)"
  mkdir -p "$pgdata" "$(svc_log_dir)" "$SVC_RUNTIME_DIR"
  if [ ! -f "$pgdata/PG_VERSION" ]; then
    echo "    initdb $pgdata"
    svc_run initdb -D "$pgdata" -U "${USER:-$(id -un)}" -E UTF8 --auth=trust >/dev/null 2>&1
  fi
  svc_run pg_ctl -D "$pgdata" status >/dev/null 2>&1 && return 0
  svc_run pg_ctl -D "$pgdata" -l "$(svc_log_dir)/postgres.log" -w \
    -o "-c unix_socket_directories=$SVC_RUNTIME_DIR -c listen_addresses=127.0.0.1 -c port=$PG_PORT" \
    start >/dev/null 2>&1 || true
}

svc_verify_postgres() {
  svc_run pg_isready -h "$SVC_RUNTIME_DIR" -p "$PG_PORT" -q 2>/dev/null
}

svc_start_redis() {
  datadir="$SVC_DATA_DIR/redis"
  mkdir -p "$datadir" "$(svc_log_dir)" "$SVC_RUNTIME_DIR"
  if [ -S "$(svc_redis_sock)" ] && svc_run redis-cli -s "$(svc_redis_sock)" ping >/dev/null 2>&1; then
    return 0
  fi
  svc_run redis-server \
    --daemonize yes \
    --dir "$datadir" \
    --unixsocket "$(svc_redis_sock)" \
    --bind 127.0.0.1 \
    --port "$REDIS_PORT" \
    --databases 1024 \
    --pidfile "$(svc_redis_pid)" \
    --logfile "$(svc_log_dir)/redis.log" >/dev/null 2>&1 || true
}

# PING over our socket proves OUR daemon is alive; CONFIG GET databases over the
# TCP port proves WE own that port — `redis-server --daemonize` exits 0 even
# when the TCP bind fails (a foreign Redis squatting the port), and apps connect
# by TCP, so a socket-only check would pass while apps hit the wrong server.
svc_verify_redis() {
  [ "$(svc_run redis-cli -s "$(svc_redis_sock)" ping 2>/dev/null)" = "PONG" ] || return 1
  [ "$(svc_run redis-cli -h 127.0.0.1 -p "$REDIS_PORT" config get databases 2>/dev/null | tail -n1)" = "1024" ]
}

# Mailpit has no unix socket (TCP only) and `--daemonize`-style detach varies by
# version, so we background it ourselves under nohup and record the pid. Health
# is pidfile + /proc/<pid>/comm — the documented carve-out from socket probing,
# with the comm check guarding against pid reuse.
svc_mailpit_running() {
  pidf="$(svc_mailpit_pid)"
  [ -f "$pidf" ] || return 1
  pid=$(cat "$pidf" 2>/dev/null)
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  case "$(svc_proc_comm "$pid")" in *mailpit*) return 0 ;; *) return 1 ;; esac
}

svc_start_mailpit() {
  mkdir -p "$(svc_log_dir)" "$SVC_RUNTIME_DIR"
  svc_mailpit_running && return 0
  svc_run sh -c "nohup mailpit \
      --db-file '$(svc_mailpit_db)' \
      --smtp '127.0.0.1:$MAIL_SMTP_PORT' \
      --listen '127.0.0.1:$MAIL_UI_PORT' \
      >> '$(svc_log_dir)/mailpit.log' 2>&1 & echo \$! > '$(svc_mailpit_pid)'"
}

# --- orchestration -----------------------------------------------------------
svc_prepare() {
  command -v mise >/dev/null 2>&1 || { echo "worktree services: mise not found on PATH" >&2; exit 1; }
  mkdir -p "$(svc_config_dir)"
  svc_write_defaults
  # Trust on every start — idempotent, and re-arms after a user edits the file.
  mise trust "$(svc_config_dir)/mise.toml" >/dev/null 2>&1 || true
  mise -C "$(svc_config_dir)" install >/dev/null 2>&1 || true
  svc_ensure_registry
  svc_load_config
}

svc_start() {
  svc_lock_acquire
  svc_prepare
  echo "==> Shared dev services (data: $SVC_DATA_DIR, sockets: $SVC_RUNTIME_DIR)"
  rc=0

  printf '    postgres (:%s) ... ' "$PG_PORT"
  svc_start_postgres
  if svc_retry svc_verify_postgres; then echo "ok"; else echo "FAILED"; rc=1; fi

  printf '    redis    (:%s) ... ' "$REDIS_PORT"
  svc_start_redis
  if svc_retry svc_verify_redis; then echo "ok"; else echo "FAILED (port may be held by another Redis)"; rc=1; fi

  printf '    mailpit  (:%s smtp, :%s ui) ... ' "$MAIL_SMTP_PORT" "$MAIL_UI_PORT"
  svc_start_mailpit
  if svc_retry svc_mailpit_running; then echo "ok"; else echo "FAILED"; rc=1; fi

  svc_lock_release
  if [ "$rc" -ne 0 ]; then
    echo "worktree services: one or more services failed verification (logs in $(svc_log_dir))" >&2
    exit 1
  fi
  echo "==> Ready. Mailpit UI: http://localhost:$MAIL_UI_PORT"
}

svc_stop() {
  svc_lock_acquire
  command -v mise >/dev/null 2>&1 || { echo "worktree services: mise not found on PATH" >&2; exit 1; }
  svc_ensure_registry
  svc_load_config
  echo "==> Stopping shared dev services"

  pgdata="$(svc_pg_data)"
  if svc_run pg_ctl -D "$pgdata" status >/dev/null 2>&1; then
    printf '    postgres ... '
    svc_run pg_ctl -D "$pgdata" -w stop >/dev/null 2>&1 && echo "stopped" || echo "(stop failed)"
  else
    echo "    postgres ... not running"
  fi

  sock="$(svc_redis_sock)"
  if [ -S "$sock" ] && svc_run redis-cli -s "$sock" ping >/dev/null 2>&1; then
    printf '    redis    ... '
    svc_run redis-cli -s "$sock" shutdown nosave >/dev/null 2>&1 || true
    echo "stopped"
  else
    echo "    redis    ... not running"
  fi

  if svc_mailpit_running; then
    printf '    mailpit  ... '
    kill "$(cat "$(svc_mailpit_pid)")" 2>/dev/null && echo "stopped" || echo "(stop failed)"
    rm -f "$(svc_mailpit_pid)"
  else
    echo "    mailpit  ... not running"
  fi

  svc_lock_release
}

# Read-only; also names a foreign listener squatting a configured TCP port (the
# port-conflict guard only fires inside start, but an old per-app daemon can sit
# on the shared port and silently accept connections — plan D6).
svc_status() {
  command -v mise >/dev/null 2>&1 || { echo "worktree services: mise not found on PATH" >&2; exit 1; }
  svc_ensure_registry
  svc_load_config
  echo "Shared dev services (data: $SVC_DATA_DIR, sockets: $SVC_RUNTIME_DIR)"

  if svc_verify_postgres; then
    echo "  postgres  up       socket $SVC_RUNTIME_DIR  tcp :$PG_PORT"
  elif svc_run pg_isready -h 127.0.0.1 -p "$PG_PORT" -q 2>/dev/null; then
    echo "  postgres  FOREIGN  another Postgres holds :$PG_PORT — stop it or change PG_PORT in $(svc_config_dir)/config"
  else
    echo "  postgres  down"
  fi

  if svc_verify_redis; then
    echo "  redis     up       socket $(svc_redis_sock)  tcp :$REDIS_PORT"
  elif svc_run redis-cli -h 127.0.0.1 -p "$REDIS_PORT" ping >/dev/null 2>&1; then
    echo "  redis     FOREIGN  another Redis holds :$REDIS_PORT — stop it or change REDIS_PORT in $(svc_config_dir)/config"
  else
    echo "  redis     down"
  fi

  if svc_verify_mailpit; then
    echo "  mailpit   up       smtp :$MAIL_SMTP_PORT  ui http://localhost:$MAIL_UI_PORT"
  else
    echo "  mailpit   down"
  fi
}

svc_verify_mailpit() { svc_mailpit_running; }

cmd_services() {
  action="${1:-}"
  case "$action" in
    start)  svc_start ;;
    stop)   svc_stop ;;
    status) svc_status ;;
    "")     echo "usage: bin/worktree services {start|stop|status}" >&2; exit 2 ;;
    *)      echo "worktree services: unknown action '$action' (start|stop|status)" >&2; exit 2 ;;
  esac
}

# Rewrite an existing worktree's .env to the current contract in place — for a
# worktree whose branch carries WIP (so rm+add is not an option) or one written
# under the old contract. Primary checkout reprovisions as slot 0. A stale .env
# otherwise overrides migrated mise [env] defaults via mise's _.file precedence.
cmd_reprovision() {
  target=""
  for arg in "$@"; do
    case "$arg" in
      --*) echo "worktree reprovision: unknown flag $arg" >&2; exit 2 ;;
      *) target="$arg" ;;
    esac
  done
  [ -n "$target" ] || target="$(pwd)"
  dest=$(resolve_worktree "$target") || exit 1
  main=$(main_worktree)

  if [ "$dest" = "$main" ]; then
    slot=0
  else
    slot=$(slot_of_env "$dest")
    [ -n "$slot" ] || { echo "worktree reprovision: $dest has no recorded slot — adopt it first" >&2; exit 1; }
  fi

  echo "==> Reprovisioning $dest (slot $slot)"
  slot_lock_acquire
  provision "$dest" "$slot"
  ensure_primary_shared
  slot_lock_release
}

# --- dispatch ----------------------------------------------------------------
[ $# -ge 1 ] || { echo "usage: bin/worktree {add|adopt|autoadopt|list|rm|reprovision|services} ..." >&2; exit 2; }
sub="$1"; shift
case "$sub" in
  add)         cmd_add "$@" ;;
  adopt)       cmd_adopt "$@" ;;
  autoadopt)   cmd_autoadopt "$@" ;;
  list)        cmd_list "$@" ;;
  rm)          cmd_rm "$@" ;;
  reprovision) cmd_reprovision "$@" ;;
  services)    cmd_services "$@" ;;
  *)           echo "bin/worktree: unknown subcommand '$sub'" >&2; exit 2 ;;
esac
